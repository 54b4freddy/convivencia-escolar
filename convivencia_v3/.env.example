# Copia este archivo como .env y ajusta los valores
# NUNCA subas el .env real a GitHub

SECRET_KEY=cambia-esta-clave-por-una-muy-segura-y-larga
FLASK_ENV=development
PORT=5000

# --- Producción / Railway (ejemplo; en Railway se suelen definir en el panel) ---
# APP_ENV=production
# DATABASE_URL=postgresql://...   # Railway Postgres lo inyecta solo al vincular el plugin
# REGISTRATION_OPEN=1             # 1 = permitir POST /api/registrar-usuario (solo pruebas; en producción omitir o 0)
# SESSION_COOKIE_SECURE=1         # Con HTTPS en Railway suele ir en 1
